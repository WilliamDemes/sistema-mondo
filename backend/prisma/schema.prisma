// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Nossa tabela que vai guardar a equipe do Instituto Mondó
model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now())
}

model Familia {
  id              Int      @id @default(autoincrement())
  nomeResponsavel String
  cpf             String?  @unique // A interrogação significa que é opcional
  endereco        String?
  telefone        String?
  criadoEm        DateTime @default(now())
  
  // Relação: Uma família pode participar de várias ações
  acoes           Acao[]   
}

// Tabela para registrar as atividades/projetos
model Acao {
  id          Int       @id @default(autoincrement())
  nome        String    // Ex: "Oficina de Leitura", "Ação de Saúde"
  descricao   String?
  dataDaAcao  DateTime?
  criadoEm    DateTime  @default(now())
  
  // Relação: Uma ação pode ter várias famílias participando
  familias    Familia[] 
}